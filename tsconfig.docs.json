{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "skipLibCheck": true
  },
  "include": [
    "packages/core-domain/src/**/*.ts",
    "packages/core-application/src/**/*.ts"
  ],
  "exclude": [
    "apps/**",
    "**/node_modules/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/dist/**",
    "**/build/**"
  ]
}