{
  "name": "@mini-sync/core-application",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm run clean && tsc -p tsconfig.json && node ./scripts/fix-esm-imports.mjs",
    "dev:watch-vault": "tsx src/dev/watch-vault.ts",
    "dev:sync-drive": "tsx src/dev/sync-drive.ts"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "@mini-sync/core-domain": "workspace:*",
    "fs-extra": "^11.3.4",
    "google-auth-library": "^10.5.0",
    "googleapis": "^170.1.0",
    "promise-retry": "^2.0.1",
    "proper-lockfile": "^4.1.2",
    "winston": "^3.19.0"
  }
}